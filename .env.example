# Copia este archivo a `.env.local` y completa los valores reales.
# NUNCA subas `.env.local` ni claves privadas al repositorio.

# Google Sheets / Calendar (cuenta de servicio)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-cuenta@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GOOGLE_SHEET_ID=
GOOGLE_CALENDAR_ID=

# Google Maps (restringe la clave por dominio/IP en Google Cloud Console)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Opcional: URL base de la API en producción (si aplica)
# NEXT_PUBLIC_API_URL=https://tu-dominio.com
